classDiagram
    %% ---------- Task hierarchy ----------
    class Task {
        <<abstract>>
        #date : Date
        #time : Time
        #durationMinutes : int
        #priority : String
        #isComplete : boolean
        +markComplete() void
        +getDate() Date
        +setDate(newDate : Date) void
        +getTime() Time
        +setTime(newTime : Time) void
        +getDurationMinutes() int
        +setDurationMinutes(minutes : int) void
        +getIsComplete() boolean
        +setIsComplete(value : boolean) void
    }

    class PetWalk {
        -distanceMiles : float
    }
    note for PetWalk "BUG: constructor accepts distanceMiles\nbut never stores it -- no self.distance_miles\nand no getter/setter exist yet.\nAlso the only subclass with no priority param."

    class Feeding {
        -foodType : String
        +getFoodType() String
        +setFoodType(newFoodType : String) void
    }

    class Medication {
        -drugName : String
        -timesPerDay : int
        -doseCounter : int
        +logDoseTaken() void
        +getDrugName() String
        +setDrugName(newDrugName : String) void
        +getTimesPerDay() int
        +setTimesPerDay(n : int) void
        +getDoseCounter() int
        +setDoseCounter(n : int) void
    }

    class VetVisit {
        -visitName : String
        -description : String
        -requiredDocumentation : String
        +getVisitName() String
        +setVisitName(newVisitName : String) void
        +getDescription() String
        +setDescription(newDescription : String) void
        +getRequiredDocumentation() String
        +setRequiredDocumentation(doc : String) void
    }

    class Other {
        -taskName : String
        +getTaskName() String
        +setTaskName(newTaskName : String) void
    }
    note for Other "BUG: constructor accepts description\nbut never stores it -- no self.description\nand no getter/setter exist yet."

    Task <|-- PetWalk
    Task <|-- Feeding
    Task <|-- Medication
    Task <|-- VetVisit
    Task <|-- Other

    %% ---------- Pet ----------
    class Pet {
        -name : String
        -age : String
        -favoriteFood : Set~String~
        -foodRestriction : Set~String~
        -medicineRestriction : Set~String~
        -task : List~Task~
        +getName() String
        +setName(newName : String) void
        +getAge() String
        +setAge(newAge : String) void
        +getFavoriteFood() Set~String~
        +setFavoriteFood(foods : Set~String~) void
        +addFavoriteFood(food : String) void
        +removeFavoriteFood(food : String) boolean
        +getFoodRestriction() Set~String~
        +setFoodRestriction(r : Set~String~) void
        +addFoodRestriction(r : String) void
        +removeFoodRestriction(r : String) boolean
        +getMedicineRestriction() Set~String~
        +setMedicineRestriction(r : Set~String~) void
        +addMedicineRestriction(r : String) void
        +removeMedicineRestriction(r : String) boolean
        +getTask() List~Task~
        +setTask(tasks : List~Task~) void
        +addTask(task : Task) void
        +removeTask(task : Task) boolean
    }
    note for Pet "petType and needsGroom from the original\ndesign were dropped; medicineRestriction\nis new. Pet now owns its own task list\ndirectly (this used to live on Calendar)."

    %% ---------- Owner (was User) ----------
    class Owner {
        -name : String
        -pets : List~Pet~
        +getAllTasks() List~Task~
        +getTodaysTasks(date : Date) void
        +getPets() List~Pet~
        +addAPet(pet : Pet) void
        +removePet(pet : Pet) boolean
        +setName(newName : String) void
    }
    note for Owner "Renamed from User. availabilitySchedules\nwas dropped entirely -- AvailabilitySchedule\nno longer exists as a class."

    Owner "1" *-- "many" Pet : owns
    Pet "1" *-- "many" Task : owns

    %% ---------- Scheduler (replaces Calendar) ----------
    class Scheduler {
        +sortTasksByTime(tasks : List~Task~) List~Task~
        +sortTasksByPriority(tasks : List~Task~) List~Task~
        +sortTasksByCompletion(tasks : List~Task~) List~Task~
        +hasTimeConflict(existing : List~Tuple~, newTime : Time, newDuration : int) boolean
        +getTasksForPet(pet : Pet) List~Task~
        +getAllTasks(owner : Owner) List~Tuple~
        +getTasksByDate(owner : Owner, date : Date) List~Tuple~
        +addTask(owner : Owner, pet : Pet, task : Task) void
        +removeTask(owner : Owner, pet : Pet, task : Task) boolean
        +completeTask(owner : Owner, pet : Pet, task : Task) boolean
    }
    note for Scheduler "Replaces Calendar. Holds no state of its own --\nowner/pet/task are passed in as parameters on\nevery call, so this is a dependency (uses), not\nan association/composition like Calendar had."

    Scheduler ..> Owner : uses
    Scheduler ..> Pet : uses
    Scheduler ..> Task : uses
